# Epi Predict Environment Variables

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# Streamlit Settings
STREAMLIT_PORT=8501

# Data Configuration
WHO_FLUNET_API_URL=https://xmart-api-public.who.int/FLUMART/VIW_FNT?$format=csv
DATA_CACHE_TTL_HOURS=24
DEFAULT_COUNTRY=India
DEFAULT_WHO_REGION=SEAR
FORECAST_WEEKS=12

# Alert System Configuration (Optional)
ALERT_EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_RECIPIENTS=user1@example.com,user2@example.com

# MLOps Configuration
MAX_MODEL_VERSIONS=10
